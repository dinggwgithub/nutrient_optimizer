{
    "swagger": "2.0",
    "info": {
        "description": "营养配餐优化请求参数",
        "title": "营养配餐多目标优化算法API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support",
            "url": "http://www.swagger.io/support",
            "email": "support@swagger.io"
        },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/api",
    "paths": {
        "/health": {
            "get": {
                "description": "检查服务是否正常运行",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "系统"
                ],
                "summary": "健康检查",
                "responses": {
                    "200": {
                        "description": "服务状态",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/ingredients": {
            "get": {
                "description": "从数据库或JSON文件获取可用的食材列表",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "食材管理"
                ],
                "summary": "获取食材列表",
                "parameters": [
                    {
                        "enum": [
                            "db",
                            "json"
                        ],
                        "type": "string",
                        "default": "db",
                        "description": "数据源 (db或json, 默认: db)",
                        "name": "source",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 20,
                        "description": "返回数量限制 (默认: 20)",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "default": "ingredients_db_export.json",
                        "description": "JSON文件路径 (source=json时使用)",
                        "name": "filepath",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "食材列表",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/optimize-moead": {
            "post": {
                "description": "使用MOEA/D（基于分解的多目标进化算法）进行营养配餐优化",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "优化算法"
                ],
                "summary": "MOEA/D多目标优化",
                "parameters": [
                    {
                        "type": "integer",
                        "default": 50,
                        "description": "种群大小 (默认: 50)",
                        "name": "population_size",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 100,
                        "description": "最大迭代次数 (默认: 100)",
                        "name": "max_iterations",
                        "in": "query"
                    },
                    {
                        "description": "优化请求参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/main.OptimizeRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "优化结果",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/optimize-with-bugs": {
            "post": {
                "description": "使用含Bug版本的优化器进行测试，用于复现特定类型的科学计算Bug",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "优化算法"
                ],
                "summary": "含Bug优化（测试版本）",
                "parameters": [
                    {
                        "enum": [
                            "precision_loss",
                            "numerical_overflow",
                            "constraint_violation",
                            "convergence_failure",
                            "result_instability"
                        ],
                        "type": "string",
                        "description": "Bug类型",
                        "name": "bug_type",
                        "in": "query",
                        "required": true
                    },
                    {
                        "description": "优化请求参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/main.OptimizeRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "优化结果（含Bug信息）",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/optimize-with-bugs-fixed": {
            "post": {
                "description": "使用修复后的优化器，专项修复收敛失败Bug：添加食材重量约束（0-500g）、优化收敛参数、消除算法随机性",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "优化算法"
                ],
                "summary": "修复Bug后的优化（修复收敛失败Bug）",
                "parameters": [
                    {
                        "type": "integer",
                        "default": 50,
                        "description": "种群大小 (默认: 50)",
                        "name": "population_size",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 100,
                        "description": "最大迭代次数 (默认: 100)",
                        "name": "max_iterations",
                        "in": "query"
                    },
                    {
                        "description": "优化请求参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/main.OptimizeRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "优化结果（修复后）",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "main.Constraint": {
            "description": "优化过程中的约束条件",
            "type": "object",
            "properties": {
                "ingredient_id": {
                    "type": "integer",
                    "example": 1
                },
                "type": {
                    "description": "\"ingredient_min\", \"ingredient_max\", \"total_weight\"",
                    "type": "string",
                    "example": "ingredient_min"
                },
                "value": {
                    "type": "number",
                    "example": 50
                }
            }
        },
        "main.Ingredient": {
            "description": "食材的营养成分信息",
            "type": "object",
            "properties": {
                "calcium": {
                    "description": "钙 (mg/100g)",
                    "type": "number",
                    "example": 11
                },
                "carbs": {
                    "description": "碳水化合物 (g/100g)",
                    "type": "number",
                    "example": 0
                },
                "energy": {
                    "description": "能量 (kcal/100g)",
                    "type": "number",
                    "example": 165
                },
                "fat": {
                    "description": "脂肪 (g/100g)",
                    "type": "number",
                    "example": 3.6
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "iron": {
                    "description": "铁 (mg/100g)",
                    "type": "number",
                    "example": 1
                },
                "name": {
                    "type": "string",
                    "example": "鸡胸肉"
                },
                "price": {
                    "description": "价格 (元/100g)",
                    "type": "number",
                    "example": 0.8
                },
                "protein": {
                    "description": "蛋白质 (g/100g)",
                    "type": "number",
                    "example": 31
                },
                "vitamin_c": {
                    "description": "维生素C (mg/100g)",
                    "type": "number",
                    "example": 0
                },
                "zinc": {
                    "description": "锌 (mg/100g)",
                    "type": "number",
                    "example": 0.7
                }
            }
        },
        "main.NutritionGoal": {
            "description": "营养素的优化目标",
            "type": "object",
            "properties": {
                "max": {
                    "description": "最大值",
                    "type": "number",
                    "example": 700
                },
                "min": {
                    "description": "最小值",
                    "type": "number",
                    "example": 500
                },
                "nutrient": {
                    "description": "营养素名称",
                    "type": "string",
                    "example": "energy"
                },
                "target": {
                    "description": "目标值",
                    "type": "number",
                    "example": 600
                },
                "weight": {
                    "description": "权重",
                    "type": "number",
                    "example": 0.3
                }
            }
        },
        "main.OptimizeRequest": {
            "type": "object",
            "properties": {
                "constraints": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/main.Constraint"
                    }
                },
                "ingredients": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/main.Ingredient"
                    }
                },
                "max_iterations": {
                    "type": "integer"
                },
                "nutrition_goals": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/main.NutritionGoal"
                    }
                },
                "tolerance": {
                    "type": "number"
                },
                "weights": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/main.Weight"
                    }
                }
            }
        },
        "main.Weight": {
            "description": "多目标优化的权重配置",
            "type": "object",
            "properties": {
                "type": {
                    "description": "\"nutrition\", \"cost\", \"variety\"",
                    "type": "string",
                    "example": "nutrition"
                },
                "value": {
                    "type": "number",
                    "example": 0.6
                }
            }
        }
    },
    "securityDefinitions": {
        "ApiKeyAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        },
        "BasicAuth": {
            "type": "basic"
        }
    }
}